[Unit]
Description=944 EV head-unit web server (app/backend/server.py)
After=network.target can0.service
Wants=can0.service

[Service]
Type=simple
User=__USER__
WorkingDirectory=__REPO__
EnvironmentFile=__REPO__/deploy/944-headunit.env
ExecStart=/usr/bin/python3 __REPO__/app/backend/server.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
